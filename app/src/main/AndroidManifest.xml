<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Permissions essentielles -->
    <!-- Requis pour la plupart des opérations réseau, y compris Firebase -->
    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Recommandé pour vérifier l'état du réseau avant de faire des appels Firebase -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <!-- Permissions pour Firebase Cloud Messaging (FCM) - Si vous utilisez les notifications push -->
    <!-- Requis sur Android 13 (API 33) et plus pour afficher les notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS"/>
    <!-- Pour les anciennes versions d'Android, FCM gère cela différemment, mais cette permission est parfois encore ajoutée par habitude ou pour des cas spécifiques -->
    <!-- <uses-permission android:name="com.google.android.c2dm.permission.RECEIVE" /> -->
    <!-- <uses-permission android:name="android.permission.WAKE_LOCK" /> --> <!-- Peut être nécessaire si vous avez des tâches en arrière-plan intensives avec FCM -->


    <application
        android:name=".MainApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LesMangeursDuRouleau"
        tools:targetApi="31">

        <!-- Activité d'Authentification - Point d'entrée -->
        <activity
            android:name=".ui.auth.AuthActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Autres activités de votre application -->
        <activity
            android:name=".MainActivity"
            android:exported="false" />
        <activity
            android:name=".ui.readings.ProposeBookActivity"
            android:exported="false" />
        <activity
            android:name=".ui.meetings.MeetingDetailActivity"
            android:exported="false" />
        <activity
            android:name=".ui.readings.BookDetailActivity"
            android:exported="false" />
        <!--
            L'activité .MainApplication listée ici semble être une erreur,
            car android:name=".MainApplication" est déjà utilisé pour la balise <application>.
            Si .MainApplication est une activité, elle devrait avoir un nom différent
            ou être retirée si elle n'est pas une activité distincte.
            Je l'ai commentée pour l'instant. Si c'est bien une activité, décommentez-la
            et assurez-vous que son nom est correct et qu'elle ne crée pas de conflit.
        -->
        <!--
        <activity
            android:name=".MainApplication"
            android:exported="false" />
        -->

        <!-- Service Firebase Cloud Messaging (FCM) - Si vous utilisez les notifications push -->
        <!-- Décommentez et assurez-vous que le nom du service correspond à votre implémentation -->
        <!--
        <service
            android:name=".MyFirebaseMessagingService"
            android:exported="false">
            <intent-filter>
                <action android:name="com.google.firebase.MESSAGING_EVENT" />
            </intent-filter>
        </service>
        -->

        <!--
             Métadonnées pour les services Google Play.
             Le plugin google-services les ajoute souvent automatiquement,
             mais il est bon de savoir qu'elles existent.
        -->
        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <!--
             Si vous utilisez Firebase ML Kit pour des modèles téléchargés,
             vous pourriez avoir besoin de ceci pour autoriser le téléchargement en arrière-plan.
        -->
        <!--
        <service
            android:name="com.google.firebase.components.ComponentDiscoveryService"
            android:directBootAware="true"
            android:exported="false"
            tools:targetApi="n">
            <meta-data
                android:name="com.google.firebase.components:com.google.firebase.ml.modeldownloader.internal.ModelDownloaderRegistrar"
                android:value="com.google.firebase.components.ComponentRegistrar" />
        </service>
        -->

    </application>

</manifest>