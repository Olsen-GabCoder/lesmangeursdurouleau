<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.LesMangeursDuRouleau" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <!-- <item name="colorPrimary">@color/my_light_primary</item> -->

        <!-- Couleurs de base de ton application (exemples, à remplacer/confirmer) -->
        <item name="colorPrimary">@color/chat_send_button_bg_dark</item> <!-- Exemple, utilise ta vraie couleur primaire -->
        <item name="colorOnPrimary">@color/chat_send_button_icon_dark</item>

        <item name="colorSurface">@color/chat_background_dark</item>
        <item name="colorOnSurface">@color/chat_input_text_dark</item>
        <item name="colorSurfaceContainer">@color/chat_input_background_dark</item>
        <item name="colorOnSurfaceVariant">@color/chat_input_hint_dark</item>
        <!-- Ajoute d'autres attributs de thème si nécessaire -->
    </style>

    <style name="Theme.LesMangeursDuRouleau" parent="Base.Theme.LesMangeursDuRouleau" />

    <!-- Styles spécifiques au Chat -->
    <style name="ChatBubbleSent">
        <item name="android:background">@drawable/bg_chat_bubble_sent_dark</item>
        <item name="android:padding">@dimen/chat_message_padding</item>
    </style>

    <style name="ChatBubbleReceived">
        <item name="android:background">@drawable/bg_chat_bubble_received_dark</item>
        <item name="android:padding">@dimen/chat_message_padding</item>
        <!-- <item name="android:layout_marginStart">@dimen/chat_bubble_margin_horizontal</item> -->
        <!-- <item name="android:layout_marginEnd">@dimen/chat_bubble_margin_horizontal</item> -->
    </style>

    <style name="ChatTextSent">
        <item name="android:textColor">@color/chat_text_sent_dark</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="ChatTextReceived">
        <item name="android:textColor">@color/chat_text_received_dark</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="ChatTimestamp">
        <item name="android:textColor">@color/chat_timestamp_dark</item>
        <item name="android:textSize">12sp</item>
    </style>

</resources>