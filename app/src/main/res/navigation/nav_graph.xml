<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/profileFragment"> <!-- Définissez votre destination de départ -->

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.lesmangeursdurouleau.app.ui.members.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_profile">

        <action
            android:id="@+id/action_profileFragment_to_membersFragment"
            app:destination="@id/membersFragment" />
        <!-- Vous pouvez ajouter d'autres actions ici si ProfileFragment peut naviguer ailleurs -->
    </fragment>

    <fragment
        android:id="@+id/membersFragment"
        android:name="com.lesmangeursdurouleau.app.ui.members.MembersFragment"
        android:label="Members"
        tools:layout="@layout/fragment_members" />

    <!-- Ajoutez ici d'autres fragments de votre application si nécessaire -->

</navigation>